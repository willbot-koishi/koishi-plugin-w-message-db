{
  "name": "koishi-plugin-w-message-db",
  "description": "WillBot: Message Database",
  "version": "2.5.1",
  "main": "lib/src/index.js",
  "typings": "lib/src/index.d.ts",
  "files": [
    "lib",
    "dist"
  ],
  "license": "MIT",
  "keywords": [
    "chatbot",
    "koishi",
    "plugin"
  ],
  "peerDependencies": {
    "@koishijs/plugin-console": "*",
    "koishi": "^4.18.9"
  },
  "dependencies": {
    "@satorijs/core": "^4.5.2",
    "@satorijs/element": "^3.1.8",
    "@vueuse/core": "^13.9.0",
    "dayjs": "^1.11.19",
    "echarts": "^6.0.0",
    "html2canvas": "^1.4.1",
    "vue-echarts": "^7.0.3"
  },
  "devDependencies": {
    "@koishijs/client": "^5.30.11",
    "@koishijs/plugin-auth": "^4.1.7",
    "@satorijs/protocol": "^1.6.1",
    "koishi-plugin-adapter-napcat": "workspace:^",
    "koishi-plugin-cron": "^3.1.0",
    "koishi-plugin-w-echarts": "workspace:^",
    "koishi-plugin-w-jieba": "workspace:^",
    "koishi-plugin-w-option-conflict": "workspace:^",
    "koishi-plugin-w-wordcloud": "workspace:^"
  },
  "koishi": {
    "service": {
      "required": [
        "database",
        "console"
      ],
      "optional": [
        "echarts"
      ],
      "implements": [
        "messageDb"
      ]
    }
  },
  "scripts": {
    "build": "yarn workspace willbot build w-message-db",
    "bump": "yarn workspace willbot bump w-message-db",
    "pub": "yarn workspace willbot pub w-message-db",
    "loc": "tokei -e '*.yml' -e '*.md' -e '*.json'"
  },
  "repository": "git+https://github.com/willbot-koishi/koishi-plugin-w-message-db"
}
